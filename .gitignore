# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- ML artifacts ---
# Trained models can be large and are reproducible from train.py — keep them out of git.
*.h5
*.keras
model/checkpoints/
model/logs/
# Exception: the exported deploy model is small (~9MB) and needed by the Docker/HF image.
!model/hotdog_classifier.h5

# --- Datasets ---
# The Kaggle dataset is large and license-bound; users download it themselves (see README).
# We keep the folder structure via .gitkeep but ignore the actual images.
# Class folders: "yes" = is a hotdog, "no" = not a hotdog.
model/data/train/yes/*
model/data/train/no/*
model/data/validation/yes/*
model/data/validation/no/*
!**/.gitkeep
# Raw Kaggle download (deleted by prepare_data.py --clean, ignored in case it lingers).
model/data/raw/
*.zip

# --- Node / React ---
node_modules/
frontend/build/
frontend/dist/
.eslintcache

# --- Env / secrets ---
.env
*.local

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp
